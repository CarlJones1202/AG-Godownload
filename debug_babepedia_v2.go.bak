package main

import (
	"fmt"
	"gallery_api/services"
	"log"
)

func main() {
	s := services.NewBabepediaService()
	name := "Nastya Nass" // Using the specific example from the user
	fmt.Printf("Searching for %s...\n", name)

	results, err := s.Search(name)
	if err != nil {
		log.Fatalf("Search failed: %v", err)
	}

	if len(results) == 0 {
		log.Fatal("No results found")
	}

	externalID := results[0].ExternalID
	fmt.Printf("Getting details for: %s (ID: %s)\n", results[0].Name, externalID)

	// Manually fetch and parse to debug text structure
	url := fmt.Sprintf("%s/babe/%s", s.BaseURL, externalID)
	// We need to use the same request logic as the service
	// Reflection or just copy-paste makeRequest logic?
	// I'll just rely on GetDetails logging if I add it, or better:
	// I will just use public GetDetails to see the bad result,
	// AND temporarily modify the service to print the raw text doc.Text() produces.

	details, err := s.GetDetails(externalID)
	if err != nil {
		log.Fatalf("GetDetails failed: %v", err)
	}

	fmt.Printf("--- Extracted Data ---\n")
	fmt.Printf("Born: %s\n", details.Birthdate)
	fmt.Printf("Birthplace: %s\n", details.Birthplace)
	fmt.Printf("Photos (%d extracted):\n", len(details.Photos))
	for i, p := range details.Photos {
		if i < 10 {
			fmt.Printf(" - %s\n", p)
		}
	}
}
